# SEC EDGAR Downloader 環境變數設定
# 複製此檔案為 .env 並填入真實資訊

# SEC User-Agent（必須填寫真實姓名和 Email）
# 格式: "Your Name your@email.com"
# 範例: "John Doe john.doe@company.com"
SEC_USER_AGENT="Your Real Name yourreal@email.com"

# 下載目錄（可選，預設為 ./downloads）
DOWNLOAD_DIR=./downloads

# Flask 環境設定
FLASK_ENV=development
FLASK_DEBUG=true

# 前端 API 目標（開發時使用）
VITE_API_TARGET=http://localhost:5000